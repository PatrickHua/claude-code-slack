# Slack Bot Token (starts with xoxb-)
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (starts with xapp-)
# Get from: https://api.slack.com/apps → Your App → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# Your Slack Channel ID for outbound messages (right-click channel → Copy link → ID is at the end)
SLACK_CHANNEL_ID=C0123456789

# Slack User Token (starts with xoxp-) — only needed for test-client.py
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions → User OAuth Token
# Required user scopes: chat:write, im:write
# SLACK_USER_TOKEN=xoxp-your-user-token-here

# ── Access control ────────────────────────────────────────────────────────────

# Global security gate: comma-separated Slack user IDs allowed to use the bot at all.
# Leave empty to allow everyone (not recommended).
# Find your user ID: click your profile → three dots → Copy member ID
ALLOWED_USERS=U0123456789

# DM policy: whether direct messages are enabled, and who can send them.
#   DM_ENABLED=true         - allow DMs (default)
#   DM_POLICY=open          - any user passing ALLOWED_USERS can DM (default)
#   DM_POLICY=allowlist     - only users in DM_ALLOW_FROM can DM
#   DM_ALLOW_FROM=U123,U456 - user IDs for DM allowlist (used when DM_POLICY=allowlist)
DM_ENABLED=true
DM_POLICY=open
# DM_ALLOW_FROM=U0123456789

# Group/channel policy: which channel messages the bot responds to.
#   GROUP_POLICY=mention    - only respond when @mentioned (default)
#   GROUP_POLICY=open       - respond to all messages in any channel
#   GROUP_POLICY=allowlist  - only respond in channels listed in GROUP_ALLOW_FROM
# GROUP_POLICY=mention
# GROUP_ALLOW_FROM=C0123456789,C9876543210

# ── Behavior ──────────────────────────────────────────────────────────────────

# Emoji reaction to add to messages while Claude is thinking (default: thinking_face)
# REACT_EMOJI=thinking_face

# Reply in a thread for channel messages (default: true). DMs are never threaded.
# REPLY_IN_THREAD=true

# ── Claude ────────────────────────────────────────────────────────────────────

# Path to your workspace with CLAUDE.md
CLAUDE_WORKSPACE=/path/to/your/workspace

# Path to claude binary (default: claude)
# CLAUDE_PATH=/usr/local/bin/claude
